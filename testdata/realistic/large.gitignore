# Large gitignore for benchmark testing

*.log
*.tmp
*.bak
*.swp
*.swo
build/
dist/
out/
target/
node_modules/
vendor/
.venv/
.git/
.svn/
.hg/
.idea/
.vscode/
*.sublime-*
.DS_Store
Thumbs.db
desktop.ini
*.pyc
*.pyo
__pycache__/
*.class
*.jar
*.o
*.a
*.so
*.dylib
*.exe
*.dll

